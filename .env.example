APP_NAME=EDINCA
APP_ENV=production
APP_KEY=
APP_DEBUG=false
APP_URL=https://api.tudominio.cl

APP_LOCALE=es
APP_FALLBACK_LOCALE=es

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_LEVEL=error

DB_CONNECTION=mysql
DB_HOST=localhost
DB_PORT=3306
DB_DATABASE=prefijo_edinca_db
DB_USERNAME=prefijo_edinca_user
DB_PASSWORD=tu_contraseña_mysql

SESSION_DRIVER=file
QUEUE_CONNECTION=sync
CACHE_STORE=file

MAIL_MAILER=smtp
MAIL_HOST=mail.tudominio.cl
MAIL_PORT=465
MAIL_USERNAME=notificaciones@tudominio.cl
MAIL_PASSWORD=tu_contraseña_correo
MAIL_ENCRYPTION=ssl
MAIL_FROM_ADDRESS=notificaciones@tudominio.cl
MAIL_FROM_NAME="EDINCA"

FRONTEND_URL=https://tudominio.cl
SANCTUM_STATEFUL_DOMAINS=tudominio.cl,www.tudominio.cl
